<!DOCTYPE html>
<html>
<head>
  <title>Task Manager</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= javascript_importmap_tags %>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
      padding: 20px;
    }
    
    .container {
      max-width: 1000px;
      margin: 0 auto;
      background: white;
      border-radius: 20px;
      padding: 30px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    }
    
    h1 {
      color: #667eea;
      margin-bottom: 30px;
      text-align: center;
      font-size: 2em;
    }
    
    .flash {
      padding: 12px;
      margin-bottom: 20px;
      border-radius: 8px;
      background: #d4edda;
      color: #155724;
      border-left: 4px solid #28a745;
    }
    
    a {
      color: #667eea;
      text-decoration: none;
    }
    
    a:hover {
      text-decoration: underline;
    }
  </style>
    <%= javascript_importmap_tags %>
</head>
<body>
  <div class="container">
    <h1>📋 Task Manager</h1>
    
    <% if notice %>
      <div class="flash"><%= notice %></div>
    <% end %>
    
    <%= yield %>
  </div>
</body>
</html>