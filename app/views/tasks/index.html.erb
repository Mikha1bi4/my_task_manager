<div style="margin-bottom: 20px;">
  <%= link_to '+ Новая задача', new_task_path, style: 'background: #667eea; color: white; padding: 10px 20px; text-decoration: none; border-radius: 8px; display: inline-block;' %>
  
  <div style="margin-top: 20px;">
    <strong>📊 Фильтр:</strong>
    <%= link_to 'Все', tasks_path, style: 'margin-left: 10px;' %> |
    <%= link_to 'Активные', tasks_path(filter: 'pending'), style: 'margin-left: 5px;' %> |
    <%= link_to 'Выполненные', tasks_path(filter: 'completed'), style: 'margin-left: 5px;' %>
  </div>
</div>

<% if @tasks.empty? %>
  <p style="text-align: center; color: #999; padding: 40px;">
    🎯 Пока нет задач. Создайте первую!
  </p>
<% else %>
  <div style="display: grid; gap: 15px;">
    <% @tasks.each do |task| %>
      <div style="border: 1px solid #e0e0e0; border-radius: 10px; padding: 15px; <%= 'opacity: 0.7; background: #f9f9f9;' if task.completed? %>">
        <div style="display: flex; justify-content: space-between; align-items: center;">
          <div>
            <h3 style="margin: 0; <%= 'text-decoration: line-through;' if task.completed? %>">
              <%= task.title %>
            </h3>
            <div style="margin-top: 8px;">
              <span style="background: #f0f0f0; padding: 3px 8px; border-radius: 5px; font-size: 12px;">
                <%= task.priority_name %>
              </span>
              <% if task.due_date %>
                <span style="margin-left: 10px; font-size: 12px; <%= 'color: red; font-weight: bold;' if task.overdue? %>">
                  📅 <%= task.due_date.strftime("%d.%m.%Y") %>
                  <%= ' ⚠️ Просрочено!' if task.overdue? %>
                </span>
              <% end %>
            </div>
          </div>
          <div style="display: flex; gap: 5px; align-items: center;">
            <%= link_to '👁️', task_path(task), title: 'Просмотр', style: 'margin-right: 8px; text-decoration: none;' %>
            <%= link_to '✏️', edit_task_path(task), title: 'Редактировать', style: 'margin-right: 8px; text-decoration: none;' %>
            
            <%= button_to '🗑️', task_path(task), 
                method: :delete,
                form: { style: 'display: inline; margin: 0; padding: 0;' },
                data: { confirm: 'Вы уверены?' },
                style: 'background: none; border: none; color: red; cursor: pointer; font-size: 16px;' %>
            
            <%= button_to task.completed? ? '↩️ Вернуть' : '✅ Выполнить', 
                toggle_complete_task_path(task), 
                method: :patch,
                form: { style: 'display: inline; margin: 0; padding: 0;' },
                style: 'background: none; border: none; color: #667eea; cursor: pointer; text-decoration: underline; font-size: 14px;' %>
          </div>
        </div>
        <% if task.description.present? %>
          <p style="margin-top: 10px; color: #666; font-size: 14px;"><%= task.description.truncate(100) %></p>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>